    def center_on_screen(self, w, h):
        sw = self.winfo_screenwidth()
        sh = self.winfo_screenheight()
        x = int((sw - w) / 2)
        y = int((sh - h) / 2)
        return f"{w}x{h}+{x}+{y}"

    # ---------- text formatting ----------
    def tag_add(self, tag_name):
        try:
            self.text.tag_add(tag_name, "sel.first", "sel.last")
        except tk.TclError:
            current_pos = self.text.index("insert")
            self.text.tag_add(tag_name, current_pos, f"{current_pos} lineend")

    def set_alignment(self, align):
        try:
            start = self.text.index("sel.first")
            end = self.text.index("sel.last")
            for tag in ["left", "center", "right"]:
                self.text.tag_remove(tag, start, end)
            self.text.tag_add(align, start, end)
        except tk.TclError:
            current_pos = self.text.index("insert")
            line_start = f"{current_pos} linestart"
            line_end = f"{current_pos} lineend"
            for tag in ["left", "center", "right"]:
                self.text.tag_remove(tag, line_start, line_end)
            self.text.tag_add(align, line_start, line_end)

    def change_font_size(self, event=None):
        size = self.font_size_var.get()
        try:
            start = self.text.index("sel.first")
            end = self.text.index("sel.last")
            tagname = f"size_{size}"
            self.text.tag_config(tagname, font=(self.font_name, size))
            self.text.tag_add(tagname, start, end)
            self.text_sizes[(start, end)] = size
            self.status_text.set(f"Font size set to {size} for selection.")
        except tk.TclError:
            current_pos = self.text.index("insert")
            tagname = f"size_{size}"
            self.text.tag_config(tagname, font=(self.font_name, size))
            self.text.tag_add(tagname, current_pos, f"{current_pos} lineend")
            self.text_sizes[(current_pos, f"{current_pos} lineend")] = size
            self.status_text.set(f"Font size set to {size} for current line.")

    def make_heading(self):
        try:
            start = self.text.index("sel.first")
            end = self.text.index("sel.last")
            for tag in ["bold", "italic", "underline", "left", "right", "center", "bullet"]:
                self.text.tag_remove(tag, start, end)
            self.text.tag_add("heading", start, end)
        except tk.TclError:
            messagebox.showinfo("Info", "Please select the text to make heading.")

    def track_cursor(self, event):
        try:
            self.last_cursor_pos = self.text.index(f"@{event.x},{event.y}")
        except Exception:
            pass

    def check_page_break_notification(self, event=None):
        try:
            cursor_line = int(self.text.index("insert").split('.')[0])
            pdf_content_height = A4[1] - (self.page_margin_top + self.page_margin_bottom + 120)
            max_lines_per_page = int(pdf_content_height / self.line_height)
            current_page = (cursor_line - 1) // max_lines_per_page
            page_end_line = (current_page + 1) * max_lines_per_page
            if cursor_line >= page_end_line - 3 and not self.page_break_notified:
                self.page_break_notified = True
                messagebox.showinfo(
                    "Page Break Notice",
                    "Page break approaching. Please type your content on the next page."
                )
            elif cursor_line < page_end_line - 3:
                self.page_break_notified = False
        except Exception:
            pass

    def change_theme_color(self):
        self.current_theme_index = (self.current_theme_index + 1) % len(self.theme_colors)
        new_color = self.theme_colors[self.current_theme_index]
        self.configure(bg=new_color)
        self.status.configure(bg=new_color)
        for widget in self.winfo_children():
            try:
                widget.configure(bg=new_color)
            except Exception:
                pass

    # ---------- image archive ----------
    def _title_for_line(self, line):
        for l in range(line - 1, 0, -1):
            txt = self.text.get(f"{l}.0", f"{l}.0 lineend").strip()
            if txt:
                return txt
        return ""

    def _add_to_archive(self, line, img):
        entry_id = id(img)
        title = self._title_for_line(line)
        self.image_archive.append({
            "id": entry_id,
            "line": line,
            "img": img,
            "width": img.size[0],
            "height": img.size[1],
            "title": title
        })

    def _update_archive_entry(self, line, new_img):
        for entry in self.image_archive:
            if entry["line"] == line:
                entry["img"] = new_img
                entry["width"], entry["height"] = new_img.size
                entry["title"] = self._title_for_line(line)
                return
        self._add_to_archive(line, new_img)

    def run_reupload_flow(self):
        if not self.image_archive:
            messagebox.showinfo("Archive", "No pages/images saved in archive.")
            return
        dlg = ArchiveDialog(self, self.image_archive)
        self.wait_window(dlg)
        entry = dlg.result
        if not entry:
            return

        # user new file: PDF+images allowed
        path = filedialog.askopenfilename(
            title=f"Select new image/PDF for line {entry['line']}",
            filetypes=[("Images or PDF", "*.jpg *.jpeg *.png *.pdf"),
                       ("Image Files", "*.jpg *.jpeg *.png"),
                       ("PDF Files", "*.pdf"),
                       ("All Files", "*.*")]
        )
        if not path:
            return

        ext = os.path.splitext(path)[1].lower()
        try:
            if ext == ".pdf":
                with pdfplumber.open(path) as pdf:
                    if not pdf.pages:
                        messagebox.showerror("Error", "PDF has no pages.")
                        return
                    page = pdf.pages[0]
                    new_img = page.to_image(resolution=300).original.convert("RGB")
            else:
                new_img = Image.open(path).convert("RGB")
        except Exception as e:
            messagebox.showerror("Error", f"Cannot open image/PDF: {e}")
            return

        target_w, target_h = entry["width"], entry["height"]
        new_img = new_img.resize((target_w, target_h), Image.LANCZOS)

        line = entry["line"]

        to_delete = []
        for img_name in self.text.image_names():
            idx = self.text.index(img_name)
            if int(idx.split('.')[0]) == line:
                to_delete.append(idx)
        for idx in to_delete:
            self.text.delete(idx)

        img_tk = ImageTk.PhotoImage(new_img)
        self.tk_images.append(img_tk)
        index_str = f"{line}.0"
        self.text.image_create(index_str, image=img_tk)

        self.tracked_images = [r for r in self.tracked_images if r[0] != line]
        self.tracked_images.append((line, new_img, "center"))

        for rec in self.pdf_images:
            if rec[0] == "img" and rec[2] == line:
                rec[3] = new_img
        for rec in self.add_docs_images:
            if rec[0] == "img" and rec[2] == line:
                rec[3] = new_img

        self._update_archive_entry(line, new_img)
        self.status_text.set(f"Page at line {line} reuploaded with new image/PDF-page.")

