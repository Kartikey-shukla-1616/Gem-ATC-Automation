                img_page = img_page.resize((1000, h), Image.LANCZOS)

            self.after(0, self._insert_pdf_page_image, img_page)
            self.after(0, self.progress_var.set, 100.0)
            self.after(0, self._pdf_paste_done)
        except Exception as e:
