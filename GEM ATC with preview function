    def prompt_add_docs(self):
        self.doc_list = filedialog.askopenfilenames(
            title="Select Additional Documents (Images / Word)",
            filetypes=[
                ("Supported Files", "*.jpg *.jpeg *.png *.doc *.docx"),
                ("Image Files", "*.jpg *.jpeg *.png"),
                ("Word Files", "*.doc *.docx"),
